# acm environment variables. All are optional; flags override env, env overrides
# defaults. Copy to .env for local use (.env is git-ignored).

# Override the resolved SQLite database path outright. When unset, acm resolves
# $CLAUDE_PROJECT_DIR/.acm/acm.db, then the nearest ancestor containing .acm,
# then <cwd>/.acm/acm.db.
# LCM_DB=/abs/path/to/project/.acm/acm.db

# Minimum log level: debug|info|warn|error (default: info).
# LOG_LEVEL=info

# Emit JSON logs instead of text (default: false).
# LOG_JSON=false
