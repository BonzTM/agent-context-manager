# --- Build stage ---
FROM golang:1.26-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /acm-web ./cmd/acm-web

# --- Runtime stage ---
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /acm-web /acm-web

EXPOSE 8080

# Health check endpoint for orchestrators that support HEALTHCHECK.
# k8s uses httpGet probes on /healthz instead.
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s \
  CMD ["/acm-web", "--version"]

USER nonroot:nonroot

ENTRYPOINT ["/acm-web"]
CMD ["serve", "--addr", ":8080"]
