{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json",
  "title": "acm CLI v1 result envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "command",
    "request_id",
    "ok",
    "timestamp"
  ],
  "properties": {
    "version": {
      "const": "acm.v1"
    },
    "command": {
      "$ref": "shared.schema.json#/$defs/commandName"
    },
    "request_id": {
      "$ref": "shared.schema.json#/$defs/requestId"
    },
    "ok": {
      "type": "boolean"
    },
    "timestamp": {
      "$ref": "shared.schema.json#/$defs/timestamp"
    },
    "result": {
      "type": "object"
    },
    "error": {
      "$ref": "shared.schema.json#/$defs/error"
    }
  },
  "$defs": {
    "contextResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok"
          ]
        },
        "receipt": {
          "$ref": "shared.schema.json#/$defs/contextReceipt"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "ok"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "required": [
              "receipt"
            ]
          }
        }
      ]
    },
    "memoryResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "status"
      ],
      "properties": {
        "candidate_id": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "promoted",
            "rejected"
          ]
        },
        "promoted_memory_id": {
          "type": "integer",
          "minimum": 1
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hard_passed",
            "soft_passed",
            "errors",
            "warnings"
          ],
          "properties": {
            "hard_passed": {
              "type": "boolean"
            },
            "soft_passed": {
              "type": "boolean"
            },
            "errors": {
              "type": "array",
              "items": {
                "type": "string",
                "maxLength": 300
              }
            },
            "warnings": {
              "type": "array",
              "items": {
                "type": "string",
                "maxLength": 300
              }
            }
          }
        }
      }
    },
    "doneResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted",
        "violations"
      ],
      "properties": {
        "accepted": {
          "type": "boolean"
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "reason"
            ],
            "properties": {
              "path": {
                "$ref": "shared.schema.json#/$defs/relativePath"
              },
              "reason": {
                "type": "string",
                "maxLength": 300
              }
            }
          }
        },
        "definition_of_done_issues": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 300
          },
          "maxItems": 100
        },
        "run_id": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "reviewExecution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_path": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "command_argv": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024,
            "pattern": "^.*\\S.*$"
          },
          "minItems": 1,
          "maxItems": 256
        },
        "command_cwd": {
          "$ref": "shared.schema.json#/$defs/relativePath"
        },
        "timeout_sec": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        },
        "exit_code": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "timed_out": {
          "type": "boolean"
        },
        "stdout_excerpt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1600,
          "pattern": "^.*\\S.*$"
        },
        "stderr_excerpt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1600,
          "pattern": "^.*\\S.*$"
        }
      }
    },
    "reviewResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_key",
        "plan_status",
        "updated",
        "review_key",
        "review_status"
      ],
      "properties": {
        "plan_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "plan_status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "complete",
            "blocked"
          ]
        },
        "updated": {
          "type": "integer",
          "minimum": 0
        },
        "task_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_key": {
          "$ref": "shared.schema.json#/$defs/contractKey"
        },
        "review_status": {
          "$ref": "shared.schema.json#/$defs/workItemStatus"
        },
        "attempts_run": {
          "type": "integer",
          "minimum": 0
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "passing_runs": {
          "type": "integer",
          "minimum": 0
        },
        "fingerprint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "skipped_reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300,
          "pattern": "^.*\\S.*$"
        },
        "executed": {
          "type": "boolean"
        },
        "execution": {
          "$ref": "#/$defs/reviewExecution"
        }
      }
    },
    "syncResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "updated",
        "marked_stale",
        "new_candidates",
        "indexed_stubs",
        "deleted_marked_stale"
      ],
      "properties": {
        "updated": {
          "type": "integer",
          "minimum": 0
        },
        "marked_stale": {
          "type": "integer",
          "minimum": 0
        },
        "new_candidates": {
          "type": "integer",
          "minimum": 0
        },
        "indexed_stubs": {
          "type": "integer",
          "minimum": 0
        },
        "deleted_marked_stale": {
          "type": "integer",
          "minimum": 0
        },
        "processed_paths": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/relativePath"
          },
          "maxItems": 2000,
          "uniqueItems": true
        }
      }
    },
    "healthCheckResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "checks"
      ],
      "properties": {
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ok",
            "total_findings"
          ],
          "properties": {
            "ok": {
              "type": "boolean"
            },
            "total_findings": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "severity",
              "count"
            ],
            "properties": {
              "name": {
                "type": "string",
                "maxLength": 100
              },
              "severity": {
                "type": "string",
                "enum": [
                  "info",
                  "warn",
                  "error"
                ]
              },
              "count": {
                "type": "integer",
                "minimum": 0
              },
              "samples": {
                "type": "array",
                "items": {
                  "type": "string",
                  "maxLength": 500
                },
                "maxItems": 100
              }
            }
          }
        }
      }
    },
    "healthFixResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run",
        "planned_actions",
        "applied_actions",
        "summary"
      ],
      "properties": {
        "dry_run": {
          "type": "boolean"
        },
        "planned_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/healthFixAction"
          },
          "maxItems": 10
        },
        "applied_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/healthFixAction"
          },
          "maxItems": 10
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "healthResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "check",
            "fix"
          ]
        },
        "check": {
          "$ref": "#/$defs/healthCheckResult"
        },
        "fix": {
          "$ref": "#/$defs/healthFixResult"
        }
      }
    },
    "healthFixAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixer",
        "count"
      ],
      "properties": {
        "fixer": {
          "type": "string",
          "enum": [
            "sync_working_tree",
            "index_unindexed_files",
            "sync_ruleset"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 300
          },
          "maxItems": 20
        }
      }
    },
    "verifySelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_id",
        "summary",
        "selection_reasons"
      ],
      "properties": {
        "test_id": {
          "$ref": "shared.schema.json#/$defs/verifyTestId"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "selection_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "minItems": 1,
          "maxItems": 16
        }
      }
    },
    "verifyTestResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_id",
        "status",
        "definition_hash"
      ],
      "properties": {
        "test_id": {
          "$ref": "shared.schema.json#/$defs/verifyTestId"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "timed_out",
            "errored",
            "skipped"
          ]
        },
        "definition_hash": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "pattern": "^sha256:[A-Za-z0-9._:-]+$"
        },
        "exit_code": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "stdout_excerpt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "stderr_excerpt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "verifyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "selected_test_ids",
        "selected",
        "passed"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "dry_run",
            "no_tests_selected",
            "passed",
            "failed"
          ]
        },
        "batch_run_id": {
          "$ref": "shared.schema.json#/$defs/requestId"
        },
        "selected_test_ids": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/verifyTestId"
          },
          "maxItems": 512,
          "uniqueItems": true
        },
        "selected": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verifySelection"
          },
          "maxItems": 512
        },
        "passed": {
          "type": "boolean"
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verifyTestResult"
          },
          "minItems": 1,
          "maxItems": 512
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "passed",
                  "failed"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "required": [
              "batch_run_id",
              "results"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "no_tests_selected"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "selected_test_ids": {
                "maxItems": 0
              },
              "selected": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "initResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_count",
        "indexed_stubs",
        "candidates_persisted"
      ],
      "properties": {
        "candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "indexed_stubs": {
          "type": "integer",
          "minimum": 0
        },
        "output_candidates_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          }
        },
        "template_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/initTemplateResult"
          },
          "maxItems": 64
        },
        "candidates_persisted": {
          "type": "boolean"
        }
      }
    },
    "initTemplateConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "reason"
      ],
      "properties": {
        "path": {
          "$ref": "shared.schema.json#/$defs/relativePath"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "initTemplateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_id"
      ],
      "properties": {
        "template_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "created": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/relativePath"
          },
          "maxItems": 256,
          "uniqueItems": true
        },
        "updated": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/relativePath"
          },
          "maxItems": 256,
          "uniqueItems": true
        },
        "unchanged": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/relativePath"
          },
          "maxItems": 256,
          "uniqueItems": true
        },
        "skipped_conflicts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/initTemplateConflict"
          },
          "maxItems": 256
        }
      }
    },
    "statusSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ready",
        "missing_count"
      ],
      "properties": {
        "ready": {
          "type": "boolean"
        },
        "missing_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "statusProject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "project_root",
        "backend",
        "unbounded"
      ],
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "project_root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "detected_repo_root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "backend": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "postgres_configured": {
          "type": "boolean"
        },
        "sqlite_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "uses_implicit_sqlite_path": {
          "type": "boolean"
        },
        "unbounded": {
          "type": "boolean"
        }
      }
    },
    "statusSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "source_path",
        "exists",
        "loaded"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "rules",
            "tags",
            "tests",
            "workflows"
          ]
        },
        "source_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "absolute_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "exists": {
          "type": "boolean"
        },
        "loaded": {
          "type": "boolean"
        },
        "item_count": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "maxItems": 32
        }
      }
    },
    "statusIntegration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "installed",
        "present_targets",
        "expected_targets"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "installed": {
          "type": "boolean"
        },
        "present_targets": {
          "type": "integer",
          "minimum": 0
        },
        "expected_targets": {
          "type": "integer",
          "minimum": 0
        },
        "missing_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          },
          "maxItems": 64
        }
      }
    },
    "statusContextPreview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "task_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "phase": {
          "$ref": "shared.schema.json#/$defs/phase"
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "unavailable"
          ]
        },
        "resolved_tags": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/tag"
          },
          "maxItems": 128,
          "uniqueItems": true
        },
        "rule_count": {
          "type": "integer",
          "minimum": 0
        },
        "memory_count": {
          "type": "integer",
          "minimum": 0
        },
        "plan_count": {
          "type": "integer",
          "minimum": 0
        },
        "initial_scope_path_count": {
          "type": "integer",
          "minimum": 0
        },
        "error": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "statusMissingItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^[a-z0-9_]+$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "statusResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "project",
        "sources",
        "integrations"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/statusSummary"
        },
        "project": {
          "$ref": "#/$defs/statusProject"
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statusSource"
          },
          "minItems": 1,
          "maxItems": 8
        },
        "integrations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statusIntegration"
          },
          "maxItems": 32
        },
        "context": {
          "$ref": "#/$defs/statusContextPreview"
        },
        "missing": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statusMissingItem"
          },
          "maxItems": 64
        }
      }
    },
    "fetchResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "items"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "key",
              "type",
              "summary"
            ],
            "properties": {
              "key": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              },
              "type": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64
              },
              "summary": {
                "type": "string",
                "minLength": 1,
                "maxLength": 4000
              },
              "content": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1000000
              },
              "status": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^.*\\S.*$"
              },
              "version": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            }
          },
          "maxItems": 2000
        },
        "not_found": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "maxItems": 2000,
          "uniqueItems": true
