{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json",
  "title": "acm CLI v1 command envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "command",
    "request_id",
    "payload"
  ],
  "properties": {
    "version": {
      "const": "acm.v1"
    },
    "command": {
      "$ref": "shared.schema.json#/$defs/commandName"
    },
    "request_id": {
      "$ref": "shared.schema.json#/$defs/requestId"
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "contextPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_text",
        "phase"
      ],
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "task_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "phase": {
          "$ref": "shared.schema.json#/$defs/phase"
        },
        "tags_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "initial_scope_paths": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/relativePath"
          },
          "maxItems": 4096,
          "uniqueItems": true
        }
      }
    },
    "memoryPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory"
      ],
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "receipt_id": {
          "$ref": "shared.schema.json#/$defs/requestId"
        },
        "plan_key": {
          "$ref": "shared.schema.json#/$defs/planKey"
        },
        "tags_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "memory": {
          "$ref": "shared.schema.json#/$defs/memoryPayload"
        },
        "auto_promote": {
          "type": "boolean",
          "default": true
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "receipt_id"
              ]
            },
            {
              "required": [
                "plan_key"
              ]
            }
          ]
        }
      ]
    },
    "donePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome"
      ],
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "receipt_id": {
          "$ref": "shared.schema.json#/$defs/requestId"
        },
        "plan_key": {
          "$ref": "shared.schema.json#/$defs/planKey"
        },
        "tags_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "files_changed": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/relativePath"
          },
          "maxItems": 256,
          "uniqueItems": true
        },
        "no_file_changes": {
          "type": "boolean",
          "default": false
        },
        "outcome": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1600
        },
        "scope_mode": {
          "type": "string",
          "enum": [
            "strict",
            "warn"
          ],
          "default": "warn"
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "receipt_id"
              ]
            },
            {
              "required": [
                "plan_key"
              ]
            }
          ]
        },
        {
          "not": {
            "required": [
              "files_changed",
              "no_file_changes"
            ],
            "properties": {
              "no_file_changes": {
                "const": true
              }
            }
          }
        }
      ]
    },
    "reviewPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "receipt_id": {
          "$ref": "shared.schema.json#/$defs/requestId"
        },
        "plan_key": {
          "$ref": "shared.schema.json#/$defs/planKey"
        },
        "key": {
          "allOf": [
            {
              "$ref": "shared.schema.json#/$defs/contractKey"
            }
          ],
          "default": "review:cross-llm"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600,
          "pattern": "^.*\\S.*$",
          "default": "Cross-LLM review"
        },
        "status": {
          "allOf": [
            {
              "$ref": "shared.schema.json#/$defs/workItemStatus"
            }
          ],
          "default": "complete"
        },
        "outcome": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1600,
          "pattern": "^.*\\S.*$"
        },
        "blocked_reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600,
          "pattern": "^.*\\S.*$"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1600,
            "pattern": "^.*\\S.*$"
          },
          "minItems": 1,
          "maxItems": 128
        },
        "run": {
          "type": "boolean",
          "default": false
        },
        "tags_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "receipt_id"
              ]
            },
            {
              "required": [
                "plan_key"
              ]
            }
          ]
        },
        {
          "if": {
            "properties": {
              "run": {
                "const": true
              }
            },
            "required": [
              "run"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "status"
                  ]
                },
                {
                  "required": [
                    "outcome"
                  ]
                },
                {
                  "required": [
                    "blocked_reason"
                  ]
                },
                {
                  "required": [
                    "evidence"
                  ]
                }
              ]
            }
          }
        }
      ]
    },
    "syncPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "mode": {
          "type": "string",
          "enum": [
            "changed",
            "full",
            "working_tree"
          ],
          "default": "changed"
        },
        "git_range": {
          "type": "string",
          "maxLength": 200,
          "default": "HEAD~1..HEAD"
        },
        "project_root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "insert_new_candidates": {
          "type": "boolean",
          "default": true
        },
        "rules_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "tags_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        }
      }
    },
    "healthPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "include_details": {
          "type": "boolean",
          "default": true
        },
        "max_findings_per_check": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "default": 100
        },
        "apply": {
          "type": "boolean",
          "default": false
        },
        "project_root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "fixers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "all",
              "sync_working_tree",
              "index_unindexed_files",
              "sync_ruleset"
            ]
          },
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true
        },
        "rules_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "tags_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        }
      }
    },
    "statusPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "project_root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "rules_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "tags_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "tests_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "workflows_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "task_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "phase": {
          "$ref": "shared.schema.json#/$defs/phase"
        }
      }
    },
    "verifyPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "receipt_id": {
          "$ref": "shared.schema.json#/$defs/requestId"
        },
        "plan_key": {
          "$ref": "shared.schema.json#/$defs/planKey"
        },
        "phase": {
          "$ref": "shared.schema.json#/$defs/phase"
        },
        "test_ids": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/verifyTestId"
          },
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true
        },
        "files_changed": {
          "type": "array",
          "items": {
            "$ref": "shared.schema.json#/$defs/relativePath"
          },
          "minItems": 1,
          "maxItems": 4096,
          "uniqueItems": true
        },
        "tests_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "tags_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "dry_run": {
          "type": "boolean",
          "default": false
        }
      },
      "allOf": [
        {
          "if": {
            "not": {
              "required": [
                "test_ids"
              ]
            }
          },
          "then": {
            "anyOf": [
              {
                "required": [
                  "receipt_id"
                ]
              },
              {
                "required": [
                  "plan_key"
                ]
              },
              {
                "required": [
                  "phase"
                ]
              },
              {
                "required": [
                  "files_changed"
                ]
              }
            ]
          }
        }
      ]
    },
    "initPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "project_root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "apply_templates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true
        },
        "respect_gitignore": {
          "type": "boolean",
          "default": true
        },
        "output_candidates_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "rules_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "tags_file": {
          "$ref": "shared.schema.json#/$defs/overrideFilePath"
        },
        "persist_candidates": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "fetchPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "keys": {
          "$ref": "shared.schema.json#/$defs/contractKeyList"
        },
        "receipt_id": {
          "$ref": "shared.schema.json#/$defs/requestId"
        },
        "expected_versions": {
          "$ref": "shared.schema.json#/$defs/expectedVersions"
        }
      },
      "anyOf": [
        {
          "required": [
            "keys"
          ]
        },
        {
          "required": [
            "receipt_id"
          ]
        }
      ],
      "allOf": [
        {
          "if": {
            "required": [
              "expected_versions"
            ]
          },
          "then": {
            "required": [
              "keys"
            ]
          }
        }
      ]
    },
    "workPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "plan_key": {
          "$ref": "shared.schema.json#/$defs/planKey"
        },
        "plan_title": {
          "$ref": "shared.schema.json#/$defs/planTitle"
        },
        "receipt_id": {
          "$ref": "shared.schema.json#/$defs/requestId"
        },
        "mode": {
          "$ref": "shared.schema.json#/$defs/workPlanMode"
        },
        "plan": {
          "$ref": "shared.schema.json#/$defs/workPlanPayload"
        },
        "tasks": {
          "$ref": "shared.schema.json#/$defs/workTasks"
        }
      },
      "anyOf": [
        {
          "required": [
            "plan_key"
          ]
        },
        {
          "required": [
            "receipt_id"
          ]
        }
      ]
    },
    "historySearchPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "$ref": "shared.schema.json#/$defs/projectId"
        },
        "entity": {
          "type": "string",
          "enum": [
            "all",
            "work",
            "memory",
            "receipt",
            "run"
          ],
          "default": "all"
        },
        "query": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "scope": {
          "type": "string",
          "enum": [
            "current",
            "deferred",
            "completed",
            "all"
          ]
        },
        "kind": {
          "$ref": "shared.schema.json#/$defs/planKind"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        },
        "unbounded": {
          "type": "boolean",
          "default": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "entity": {
                "enum": [
                  "all",
                  "memory",
                  "receipt",
                  "run"
                ]
              }
            },
            "required": [
              "entity"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "scope"
                  ]
                },
                {
                  "required": [
                    "kind"
                  ]
                }
              ]
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command": {
            "const": "context"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/contextPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "fetch"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/fetchPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "memory"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/memoryPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "done"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/donePayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "review"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/reviewPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "work"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/workPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "sync"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/syncPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "health"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/healthPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "status"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/statusPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "verify"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/verifyPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "init"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/initPayload"
          }
        }
      }
    }
  ]
}
