{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-context-manager.dev/spec/v1/shared.schema.json",
  "title": "acm v1 shared schema",
  "type": "object",
  "$defs": {
    "requestId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "projectId": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "overrideFilePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "phase": {
      "type": "string",
      "enum": [
        "plan",
        "execute",
        "review"
      ]
    },
    "verifyTestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "tag": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "tagList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tag"
      },
      "maxItems": 64,
      "uniqueItems": true
    },
    "pointerKind": {
      "type": "string",
      "enum": [
        "code",
        "rule",
        "doc",
        "test",
        "command"
      ]
    },
    "pointerKey": {
      "type": "string",
      "minLength": 3,
      "maxLength": 512,
      "pattern": "^[^\\s]+:[^\\s#]+(?:#[^\\s]+)?$"
    },
    "contractKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^.*\\S.*$"
    },
    "contractKeyList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contractKey"
      },
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true
    },
    "expectedVersions": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/contractKey"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^.*\\S.*$"
      },
      "maxProperties": 256
    },
    "planKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^plan:[A-Za-z0-9._:-]{8,128}$"
    },
    "planTitle": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^.*\\S.*$"
    },
    "workPlanMode": {
      "type": "string",
      "enum": [
        "merge",
        "replace"
      ]
    },
    "planKind": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9_-]{0,63}$"
    },
    "externalRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048,
        "pattern": "^.*\\S.*$"
      },
      "maxItems": 256
    },
    "workItemStatus": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "complete",
        "blocked",
        "superseded"
      ]
    },
    "workItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "summary",
        "status"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/contractKey"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600,
          "pattern": "^.*\\S.*$"
        },
        "status": {
          "$ref": "#/$defs/workItemStatus"
        },
        "outcome": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1600,
          "pattern": "^.*\\S.*$"
        }
      }
    },
    "workItems": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workItem"
      },
      "minItems": 0,
      "maxItems": 256
    },
    "workPlanStages": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spec_outline": {
          "$ref": "#/$defs/workItemStatus"
        },
        "refined_spec": {
          "$ref": "#/$defs/workItemStatus"
        },
        "implementation_plan": {
          "$ref": "#/$defs/workItemStatus"
        }
      }
    },
    "workPlanPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "$ref": "#/$defs/planTitle"
        },
        "objective": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "pattern": "^.*\\S.*$"
        },
        "kind": {
          "$ref": "#/$defs/planKind"
        },
        "parent_plan_key": {
          "$ref": "#/$defs/planKey"
        },
        "status": {
          "$ref": "#/$defs/workItemStatus"
        },
        "stages": {
          "$ref": "#/$defs/workPlanStages"
        },
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600,
            "pattern": "^.*\\S.*$"
          },
          "maxItems": 128
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600,
            "pattern": "^.*\\S.*$"
          },
          "maxItems": 128
        },
        "discovered_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relativePath"
          },
          "maxItems": 4096,
          "uniqueItems": true
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600,
            "pattern": "^.*\\S.*$"
          },
          "maxItems": 128
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048,
            "pattern": "^.*\\S.*$"
          },
          "maxItems": 256
        },
        "external_refs": {
          "$ref": "#/$defs/externalRefs"
        }
      }
    },
    "workTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "summary",
        "status"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/contractKey"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600,
          "pattern": "^.*\\S.*$"
        },
        "status": {
          "$ref": "#/$defs/workItemStatus"
        },
        "parent_task_key": {
          "$ref": "#/$defs/contractKey"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contractKey"
          },
          "maxItems": 128
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600,
            "pattern": "^.*\\S.*$"
          },
          "maxItems": 128
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048,
            "pattern": "^.*\\S.*$"
          },
          "maxItems": 256
        },
        "external_refs": {
          "$ref": "#/$defs/externalRefs"
        },
        "blocked_reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600,
          "pattern": "^.*\\S.*$"
        },
        "outcome": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1600,
          "pattern": "^.*\\S.*$"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1600,
            "pattern": "^.*\\S.*$"
          },
          "maxItems": 128
        }
      }
    },
    "workTasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workTask"
      },
      "minItems": 0,
      "maxItems": 256
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "not": {
        "pattern": "^(?:/|[A-Za-z]:\\\\)"
      }
    },
    "pointerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "path",
        "kind",
        "label",
        "description",
        "why"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/pointerKey"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "anchor": {
          "type": "string",
          "maxLength": 256
        },
        "kind": {
          "$ref": "#/$defs/pointerKind"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1200
        },
        "why": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "minItems": 1,
          "maxItems": 8
        }
      }
    },
    "memoryCategory": {
      "type": "string",
      "enum": [
        "decision",
        "gotcha",
        "pattern",
        "preference"
      ]
    },
    "memorySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "subject",
        "content",
        "confidence",
        "why"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "confidence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "why": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "minItems": 1,
          "maxItems": 8
        }
      }
    },
    "contextRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "key",
        "summary",
        "enforcement"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/contractKey"
        },
        "key": {
          "$ref": "#/$defs/contractKey"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600,
          "pattern": "^.*\\S.*$"
        },
        "enforcement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^.*\\S.*$"
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20000,
          "pattern": "^.*\\S.*$"
        }
      }
    },
    "contextMemory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "summary"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/contractKey"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600,
          "pattern": "^.*\\S.*$"
        }
      }
    },
    "contextPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "summary",
        "status"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/contractKey"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600,
          "pattern": "^.*\\S.*$"
        },
        "status": {
          "$ref": "#/$defs/workItemStatus"
        },
        "fetch_keys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contractKey"
          },
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true
        }
      }
    },
    "contextPlanTaskCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "pending",
        "in_progress",
        "blocked",
        "complete"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "pending": {
          "type": "integer",
          "minimum": 0
        },
        "in_progress": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "complete": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "contextReceiptMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "project_id",
        "task_text",
        "phase",
        "resolved_tags",
        "baseline_captured"
      ],
      "properties": {
        "receipt_id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "project_id": {
          "$ref": "#/$defs/projectId"
        },
        "task_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "phase": {
          "$ref": "#/$defs/phase"
        },
        "resolved_tags": {
          "$ref": "#/$defs/tagList"
        },
        "baseline_captured": {
          "type": "boolean"
        }
      }
    },
    "contextReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rules",
        "memories",
        "plans",
        "_meta"
      ],
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextRule"
          }
        },
        "memories": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextMemory"
          }
        },
        "plans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextPlan"
          }
        },
        "initial_scope_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relativePath"
          },
          "maxItems": 4096,
          "uniqueItems": true
        },
        "_meta": {
          "$ref": "#/$defs/contextReceiptMeta"
        }
      }
    },
    "memoryPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "subject",
        "content",
        "related_pointer_keys",
        "tags",
        "confidence",
        "evidence_pointer_keys"
      ],
      "properties": {
        "category": {
          "$ref": "#/$defs/memoryCategory"
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "related_pointer_keys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pointerKey"
          },
          "maxItems": 32,
          "uniqueItems": true
        },
        "tags": {
          "$ref": "#/$defs/tagList"
        },
        "confidence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "evidence_pointer_keys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pointerKey"
          },
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Z0-9_]+$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "details": {
          "type": "object"
        }
      }
    },
    "commandName": {
      "type": "string",
      "enum": [
        "context",
        "fetch",
        "memory",
        "done",
        "review",
        "work",
        "history",
        "sync",
        "health",
        "status",
        "verify",
        "init"
      ]
    }
  }
}
