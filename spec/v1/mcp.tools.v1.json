{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-context-manager.dev/spec/v1/mcp.tools.v1.json",
  "title": "acm MCP v1 tool contracts",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "tools"
  ],
  "properties": {
    "version": {
      "const": "acm.v1"
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/toolContract"
      },
      "minItems": 14,
      "maxItems": 14
    }
  },
  "$defs": {
    "toolContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "title",
        "description",
        "input_schema",
        "output_schema"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "get_context",
            "fetch",
            "propose_memory",
            "report_completion",
            "review",
            "work",
            "history_search",
            "sync",
            "health_check",
            "health_fix",
            "coverage",
            "eval",
            "verify",
            "bootstrap"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "input_schema": {
          "type": "object"
        },
        "output_schema": {
          "type": "object"
        }
      }
    },
    "getContextInput": {
      "$ref": "cli.command.schema.json#/$defs/getContextPayload"
    },
    "getContextOutput": {
      "$ref": "cli.result.schema.json#/$defs/getContextResult"
    },
    "fetchInput": {
      "$ref": "cli.command.schema.json#/$defs/fetchPayload"
    },
    "fetchOutput": {
      "$ref": "cli.result.schema.json#/$defs/fetchResult"
    },
    "proposeMemoryInput": {
      "$ref": "cli.command.schema.json#/$defs/proposeMemoryPayload"
    },
    "proposeMemoryOutput": {
      "$ref": "cli.result.schema.json#/$defs/proposeMemoryResult"
    },
    "reportCompletionInput": {
      "$ref": "cli.command.schema.json#/$defs/reportCompletionPayload"
    },
    "reportCompletionOutput": {
      "$ref": "cli.result.schema.json#/$defs/reportCompletionResult"
    },
    "reviewInput": {
      "$ref": "cli.command.schema.json#/$defs/reviewPayload"
    },
    "reviewOutput": {
      "$ref": "cli.result.schema.json#/$defs/reviewResult"
    },
    "workInput": {
      "$ref": "cli.command.schema.json#/$defs/workPayload"
    },
    "workOutput": {
      "$ref": "cli.result.schema.json#/$defs/workResult"
    },
    "syncInput": {
      "$ref": "cli.command.schema.json#/$defs/syncPayload"
    },
    "syncOutput": {
      "$ref": "cli.result.schema.json#/$defs/syncResult"
    },
    "healthCheckInput": {
      "$ref": "cli.command.schema.json#/$defs/healthCheckPayload"
    },
    "healthCheckOutput": {
      "$ref": "cli.result.schema.json#/$defs/healthCheckResult"
    },
    "healthFixInput": {
      "$ref": "cli.command.schema.json#/$defs/healthFixPayload"
    },
    "healthFixOutput": {
      "$ref": "cli.result.schema.json#/$defs/healthFixResult"
    },
    "coverageInput": {
      "$ref": "cli.command.schema.json#/$defs/coveragePayload"
    },
    "coverageOutput": {
      "$ref": "cli.result.schema.json#/$defs/coverageResult"
    },
    "evalInput": {
      "$ref": "cli.command.schema.json#/$defs/evalPayload"
    },
    "evalOutput": {
      "$ref": "cli.result.schema.json#/$defs/evalResult"
    },
    "verifyInput": {
      "$ref": "cli.command.schema.json#/$defs/verifyPayload"
    },
    "verifyOutput": {
      "$ref": "cli.result.schema.json#/$defs/verifyResult"
    },
    "bootstrapInput": {
      "$ref": "cli.command.schema.json#/$defs/bootstrapPayload"
    },
    "bootstrapOutput": {
      "$ref": "cli.result.schema.json#/$defs/bootstrapResult"
    },
    "historySearchInput": {
      "$ref": "cli.command.schema.json#/$defs/historySearchPayload"
    },
    "historySearchOutput": {
      "$ref": "cli.result.schema.json#/$defs/historySearchResult"
    }
  },
  "version": "acm.v1",
  "tools": [
    {
      "name": "get_context",
      "title": "Get Task Context",
      "description": "Deterministically resolve task-scoped pointers, rules, and memories.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/getContextPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/getContextResult"
      }
    },
    {
      "name": "fetch",
      "title": "Fetch Task Context",
      "description": "Fetch deterministic task context by pointer keys and optional expected versions.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/fetchPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/fetchResult"
      }
    },
    {
      "name": "propose_memory",
      "title": "Propose Durable Memory",
      "description": "Submit a memory candidate tied to evidence and receipt scope.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/proposeMemoryPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/proposeMemoryResult"
      }
    },
    {
      "name": "report_completion",
      "title": "Report Task Completion",
      "description": "Validate changed files against the active receipt and persist run summary.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/reportCompletionPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/reportCompletionResult"
      }
    },
    {
      "name": "review",
      "title": "Record Review Gate",
      "description": "Record or execute a single review task gate such as review:cross-llm through the work tracker.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/reviewPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/reviewResult"
      }
    },
    {
      "name": "work",
      "title": "Submit Completion Work",
      "description": "Submit plan-scoped work task updates with status and optional outcomes.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/workPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/workResult"
      }
    },
    {
      "name": "history_search",
      "title": "Search History",
      "description": "List or search work plans, memories, receipts, and runs without direct database access.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/historySearchPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/historySearchResult"
      }
    },
    {
      "name": "sync",
      "title": "Sync Project Inventory",
      "description": "Refresh indexed repository pointers from git or the working tree.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/syncPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/syncResult"
      }
    },
    {
      "name": "health_check",
      "title": "Check Project Health",
      "description": "Inspect ACM repository health and return findings without making changes.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/healthCheckPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/healthCheckResult"
      }
    },
    {
      "name": "health_fix",
      "title": "Fix Project Health",
      "description": "Plan or apply ACM health fixes such as ruleset sync and working tree repair.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/healthFixPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/healthFixResult"
      }
    },
    {
      "name": "coverage",
      "title": "Measure Coverage",
      "description": "Report repository indexing coverage against the current project tree.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/coveragePayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/coverageResult"
      }
    },
    {
      "name": "eval",
      "title": "Run Retrieval Evaluation",
      "description": "Run retrieval evaluation cases against ACM context selection behavior.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/evalPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/evalResult"
      }
    },
    {
      "name": "verify",
      "title": "Run Executable Verification",
      "description": "Select and execute repo-defined verification checks from acm test definitions.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/verifyPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/verifyResult"
      }
    },
    {
      "name": "bootstrap",
      "title": "Bootstrap Repository",
      "description": "Scan a repository, seed ACM files, and optionally apply additive bootstrap templates.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.command.schema.json#/$defs/bootstrapPayload"
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$ref": "https://agent-context-manager.dev/spec/v1/cli.result.schema.json#/$defs/bootstrapResult"
      }
    }
  ]
}
